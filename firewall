#!/bin/bash

sudo apt update
sudo apt install -y iptables iptables-persistent

iptables -F
iptables -X

iptables -t nat -F
iptables -t nat -X

iptables -t mangle -F
iptables -t mangle -X

iptables -t raw -F
iptables -t raw -X

iptables -P INPUT DROP
iptables -P FORWARD DROP
iptables -P OUTPUT DROP

ip6tables -F
ip6tables -X

ip6tables -t nat -F 2>/dev/null
ip6tables -t nat -X 2>/dev/null

ip6tables -t mangle -F
ip6tables -t mangle -X

ip6tables -t raw -F
ip6tables -t raw -X

ip6tables -P INPUT DROP
ip6tables -P FORWARD DROP
ip6tables -P OUTPUT DROP

systemctl restart docker
systemctl restart tailscaled

sleep 3

# INPUT IPv4
iptables -A INPUT -i lo -j ACCEPT
iptables -A INPUT -m conntrack --ctstate INVALID -j DROP
iptables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -A INPUT -i tailscale0 -j ACCEPT

iptables -A FORWARD -m conntrack --ctstate INVALID -j DROP
iptables -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -I FORWARD 1 -i tailscale0 -j ACCEPT
iptables -I FORWARD 2 -o tailscale0 -j ACCEPT

iptables -A OUTPUT -o lo -j ACCEPT
iptables -A OUTPUT -m conntrack --ctstate INVALID -j DROP
iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -A OUTPUT -o tailscale0 -j ACCEPT

iptables -A OUTPUT -p tcp --dport 80 -j ACCEPT
iptables -A OUTPUT -p tcp --dport 443 -j ACCEPT
iptables -A OUTPUT -p udp --dport 443 -j ACCEPT

iptables -A OUTPUT -p tcp --dport 25 -j ACCEPT
iptables -A OUTPUT -p tcp --dport 465 -j ACCEPT
iptables -A OUTPUT -p tcp --dport 587 -j ACCEPT

iptables -A OUTPUT -p udp --dport 53 -j ACCEPT
iptables -A OUTPUT -p tcp --dport 53 -j ACCEPT

iptables -A OUTPUT -p udp --dport 41641 -j ACCEPT
iptables -A OUTPUT -p udp --dport 3478 -j ACCEPT

iptables -A OUTPUT -p udp --dport 7844 -j ACCEPT
iptables -A OUTPUT -p tcp --dport 7844 -j ACCEPT

iptables -A OUTPUT -p udp --dport 123 -j ACCEPT

iptables -I DOCKER-USER 1 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -I DOCKER-USER 2 -i tailscale0 -j ACCEPT
iptables -I DOCKER-USER 3 -o tailscale0 -j ACCEPT
iptables -A DOCKER-USER -j DROP

ip6tables -A INPUT -i lo -j ACCEPT
ip6tables -A INPUT -m conntrack --ctstate INVALID -j DROP
ip6tables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
ip6tables -A INPUT -i tailscale0 -j ACCEPT
ip6tables -A INPUT -p ipv6-icmp -j ACCEPT

ip6tables -A FORWARD -m conntrack --ctstate INVALID -j DROP
ip6tables -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
ip6tables -I FORWARD 1 -i tailscale0 -j ACCEPT
ip6tables -I FORWARD 2 -o tailscale0 -j ACCEPT
ip6tables -A FORWARD -p ipv6-icmp -j ACCEPT

ip6tables -A OUTPUT -o lo -j ACCEPT
ip6tables -A OUTPUT -m conntrack --ctstate INVALID -j DROP
ip6tables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
ip6tables -A OUTPUT -o tailscale0 -j ACCEPT
ip6tables -A OUTPUT -p ipv6-icmp -j ACCEPT

ip6tables -A OUTPUT -p tcp --dport 80 -j ACCEPT
ip6tables -A OUTPUT -p tcp --dport 443 -j ACCEPT
ip6tables -A OUTPUT -p udp --dport 443 -j ACCEPT

ip6tables -A OUTPUT -p tcp --dport 25 -j ACCEPT
ip6tables -A OUTPUT -p tcp --dport 465 -j ACCEPT
ip6tables -A OUTPUT -p tcp --dport 587 -j ACCEPT

ip6tables -A OUTPUT -p udp --dport 53 -j ACCEPT
ip6tables -A OUTPUT -p tcp --dport 53 -j ACCEPT

ip6tables -A OUTPUT -p udp --dport 41641 -j ACCEPT
ip6tables -A OUTPUT -p udp --dport 3478 -j ACCEPT

ip6tables -A OUTPUT -p udp --dport 7844 -j ACCEPT
ip6tables -A OUTPUT -p tcp --dport 7844 -j ACCEPT

ip6tables -A OUTPUT -p udp --dport 123 -j ACCEPT

ip6tables -I DOCKER-USER 1 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
ip6tables -I DOCKER-USER 2 -i tailscale0 -j ACCEPT
ip6tables -I DOCKER-USER 3 -o tailscale0 -j ACCEPT
ip6tables -A DOCKER-USER -j DROP

netfilter-persistent save
netfilter-persistent reload

echo "Configuração do Firewall finalizada."



